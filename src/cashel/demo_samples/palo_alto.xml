<?xml version="1.0" encoding="UTF-8"?>
<!-- Palo Alto Networks PAN-OS Running Configuration Example -->
<!-- Device: PA-EDGE-01 | Platform: PA-3220 | PAN-OS 11.1.2 -->
<!-- Export: show config running | Panorama-managed -->
<config version="11.1.0" urldb="paloaltonetworks">
  <devices>
    <entry name="localhost.localdomain">
      <deviceconfig>
        <system>
          <hostname>PA-EDGE-01</hostname>
          <domain>corp.example.com</domain>
          <login-banner>AUTHORIZED ACCESS ONLY. Unauthorized access is prohibited.</login-banner>
          <timezone>US/Eastern</timezone>
          <update-server>updates.paloaltonetworks.com</update-server>
          <dns-setting>
            <servers>
              <primary>10.40.1.53</primary>
              <secondary>8.8.8.8</secondary>
            </servers>
          </dns-setting>
          <ntp-servers>
            <primary-ntp-server>
              <ntp-server-address>pool.ntp.org</ntp-server-address>
            </primary-ntp-server>
          </ntp-servers>
        </system>
        <setting>
          <management>
            <idle-timeout>10</idle-timeout>
            <admin-lockout>
              <failed-attempts>5</failed-attempts>
              <lockout-time>30</lockout-time>
            </admin-lockout>
          </management>
        </setting>
      </deviceconfig>

      <vsys>
        <entry name="vsys1">

          <!-- ── Zone Definitions ─────────────────────────────────────── -->
          <zone>
            <entry name="untrust">
              <network>
                <layer3>
                  <member>ethernet1/1</member>
                </layer3>
              </network>
              <zone-protection-profile>Zone-Protection-Untrust</zone-protection-profile>
              <log-forwarding>Panorama-Log-Profile</log-forwarding>
            </entry>
            <entry name="trust">
              <network>
                <layer3>
                  <member>ethernet1/2</member>
                </layer3>
              </network>
            </entry>
            <entry name="dmz">
              <network>
                <layer3>
                  <member>ethernet1/3</member>
                </layer3>
              </network>
            </entry>
          </zone>

          <!-- ── Address Objects ─────────────────────────────────────── -->
          <address>
            <entry name="WEB-SERVER-01">
              <ip-netmask>172.16.40.10/32</ip-netmask>
              <description>Primary web server in DMZ</description>
            </entry>
            <entry name="WEB-SERVER-02">
              <ip-netmask>172.16.40.11/32</ip-netmask>
              <description>Secondary web server in DMZ</description>
            </entry>
            <entry name="APP-NET">
              <ip-netmask>10.40.20.0/24</ip-netmask>
              <description>Application server subnet</description>
            </entry>
            <entry name="DB-NET">
              <ip-netmask>10.40.30.0/24</ip-netmask>
              <description>Database server subnet</description>
            </entry>
            <entry name="MGMT-HOSTS">
              <ip-netmask>10.40.99.0/24</ip-netmask>
              <description>Management jump hosts</description>
            </entry>
          </address>

          <!-- ── Address Groups ──────────────────────────────────────── -->
          <address-group>
            <entry name="GRP-WEB-SERVERS">
              <static>
                <member>WEB-SERVER-01</member>
                <member>WEB-SERVER-02</member>
              </static>
              <description>DMZ web server group</description>
            </entry>
          </address-group>

          <!-- ── Service Objects ─────────────────────────────────────── -->
          <service>
            <entry name="SVC-APP-8080">
              <protocol>
                <tcp>
                  <port>8080</port>
                </tcp>
              </protocol>
              <description>Application HTTP port</description>
            </entry>
            <entry name="SVC-APP-8443">
              <protocol>
                <tcp>
                  <port>8443</port>
                </tcp>
              </protocol>
              <description>Application HTTPS port</description>
            </entry>
          </service>

          <!-- ── Security Policies ───────────────────────────────────── -->
          <security>
            <rules>
              <!-- FINDING: any-any permit with any application — AUDIT WILL FLAG THIS -->
              <entry name="Allow-Any-Any">
                <from><member>any</member></from>
                <to><member>any</member></to>
                <source><member>any</member></source>
                <destination><member>any</member></destination>
                <application><member>any</member></application>
                <service><member>any</member></service>
                <action>allow</action>
                <profile-setting>
                  <group><member>default</member></group>
                </profile-setting>
                <!-- FINDING: missing description — AUDIT WILL FLAG THIS -->
                <!-- FINDING: missing log-end — AUDIT WILL FLAG THIS -->
              </entry>

              <!-- Inbound web to DMZ — properly scoped -->
              <entry name="Internet-to-DMZ-Web">
                <from><member>untrust</member></from>
                <to><member>dmz</member></to>
                <source><member>any</member></source>
                <destination><member>GRP-WEB-SERVERS</member></destination>
                <application>
                  <member>web-browsing</member>
                  <member>ssl</member>
                </application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <profile-setting>
                  <group><member>Strict-Security-Profile</member></group>
                </profile-setting>
                <log-end>yes</log-end>
                <description>Inbound HTTP/HTTPS to DMZ web servers</description>
              </entry>

              <!-- DMZ to App tier -->
              <entry name="DMZ-to-App">
                <from><member>dmz</member></from>
                <to><member>trust</member></to>
                <source><member>GRP-WEB-SERVERS</member></source>
                <destination><member>APP-NET</member></destination>
                <application><member>SVC-APP-8080</member></application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <log-end>yes</log-end>
                <description>Web tier to application tier port 8080</description>
              </entry>

              <!-- App to DB tier -->
              <entry name="App-to-DB">
                <from><member>trust</member></from>
                <to><member>trust</member></to>
                <source><member>APP-NET</member></source>
                <destination><member>DB-NET</member></destination>
                <application>
                  <member>mssql</member>
                  <member>postgresql</member>
                </application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <log-end>yes</log-end>
                <description>Application tier to database tier</description>
              </entry>

              <!-- Inside to Internet (egress) -->
              <entry name="Trust-to-Internet">
                <from><member>trust</member></from>
                <to><member>untrust</member></to>
                <source><member>any</member></source>
                <destination><member>any</member></destination>
                <application>
                  <member>web-browsing</member>
                  <member>ssl</member>
                  <member>dns</member>
                  <member>smtp</member>
                </application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <profile-setting>
                  <group><member>Outbound-Security-Profile</member></group>
                </profile-setting>
                <log-end>yes</log-end>
                <description>Permitted egress with App-ID enforcement</description>
              </entry>

              <!-- FINDING: duplicate of Internet-to-DMZ-Web — AUDIT WILL FLAG THIS -->
              <entry name="Allow-Web-Duplicate">
                <from><member>untrust</member></from>
                <to><member>dmz</member></to>
                <source><member>any</member></source>
                <destination><member>GRP-WEB-SERVERS</member></destination>
                <application>
                  <member>web-browsing</member>
                  <member>ssl</member>
                </application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <log-end>yes</log-end>
                <description>Duplicate of Internet-to-DMZ-Web</description>
              </entry>

              <!-- Management access -->
              <entry name="Mgmt-Access">
                <from><member>trust</member></from>
                <to><member>trust</member></to>
                <source><member>MGMT-HOSTS</member></source>
                <destination><member>any</member></destination>
                <application>
                  <member>ssh</member>
                  <member>ssl</member>
                </application>
                <service><member>application-default</member></service>
                <action>allow</action>
                <log-end>yes</log-end>
                <description>Management jump host access</description>
              </entry>

              <!-- Explicit deny-all -->
              <entry name="Deny-All">
                <from><member>any</member></from>
                <to><member>any</member></to>
                <source><member>any</member></source>
                <destination><member>any</member></destination>
                <application><member>any</member></application>
                <service><member>any</member></service>
                <action>deny</action>
                <log-end>yes</log-end>
                <description>Explicit deny-all catch-all</description>
              </entry>
            </rules>
          </security>

          <!-- ── NAT Policies ────────────────────────────────────────── -->
          <nat>
            <rules>
              <entry name="SNAT-Trust-to-Internet">
                <from><member>trust</member></from>
                <to><member>untrust</member></to>
                <source><member>any</member></source>
                <destination><member>any</member></destination>
                <service>any</service>
                <to-interface>ethernet1/1</to-interface>
                <source-translation>
                  <dynamic-ip-and-port>
                    <interface-address>
                      <interface>ethernet1/1</interface>
                    </interface-address>
                  </dynamic-ip-and-port>
                </source-translation>
                <description>Outbound SNAT for trust zone</description>
              </entry>
              <entry name="DNAT-WEB-SERVER-01">
                <from><member>untrust</member></from>
                <to><member>untrust</member></to>
                <source><member>any</member></source>
                <destination><member>203.0.113.30/32</member></destination>
                <service>any</service>
                <destination-translation>
                  <translated-address>WEB-SERVER-01</translated-address>
                </destination-translation>
                <description>DNAT public IP to web server 01</description>
              </entry>
            </rules>
          </nat>

        </entry>
      </vsys>
    </entry>
  </devices>
</config>
